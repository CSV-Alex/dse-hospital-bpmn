      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.reporteFalla ){",
        "\treturn {",
        "\t\t//map reporteFalla variable to expected task contract input",
        "\t\treporteFallaInput: {",
        "\t\t\trequiereReparacion: $data.reporteFalla.requiereReparacion !== undefined ? $data.reporteFalla.requiereReparacion : null",
