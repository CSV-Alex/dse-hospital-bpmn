      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.inventarioAux ){",
        "\treturn {",
        "\t\t//map inventarioAux variable to expected task contract input",
        "\t\tinventarioAuxInput: {",
        "\t\t\tnombre: $data.inventarioAux.nombre !== undefined ? $data.inventarioAux.nombre : null,",
        "\t\t\tstockDisponible: $data.inventarioAux.stockDisponible !== undefined ? $data.inventarioAux.stockDisponible : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
