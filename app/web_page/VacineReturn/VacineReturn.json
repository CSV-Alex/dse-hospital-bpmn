    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "solicitud" : {
      "type" : "url",
      "value" : [
        "../{{context.solicitud_ref.link}}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.campaign_report && $data.solicitud ){",
        "\treturn {",
        "\t\t//map campaign_report variable to expected task contract input",
        "\t\tcampaign_reportInput: {",
        "\t\t\tcompleted: $data.campaign_report.completed !== undefined ? $data.campaign_report.completed : null",
        "\t\t},",
        "\t\t//map solicitud variable to expected task contract input",
        "\t\tsolicitudInput: {",
        "\t\t\tapproved: $data.solicitud.approved !== undefined ? $data.solicitud.approved : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
