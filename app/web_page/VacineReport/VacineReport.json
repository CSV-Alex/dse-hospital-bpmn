  "variables" : {
    "campaign_report" : {
      "type" : "url",
      "value" : [
        "../{{context.campaign_report_ref.link}}"
      ],
      "exposed" : false
    },
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "solicitud" : {
      "type" : "url",
      "value" : [
        "../{{context.solicitud_ref.link}}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.campaign_report && $data.solicitud ){",
        "\treturn {",
        "\t\t//map campaign_report variable to expected task contract input",
        "\t\tcampaign_reportInput: {",
        "\t\t\tvacunados: $data.campaign_report.vacunados !== undefined ? $data.campaign_report.vacunados : null",
        "\t\t},",
        "\t\t//map solicitud variable to expected task contract input",
        "\t\tsolicitudInput: {",
        "\t\t\tencargadoCampaign: $data.solicitud.encargadoCampaign !== undefined ? $data.solicitud.encargadoCampaign : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    }
