  "variables" : {
    "campaign_report" : {
      "type" : "url",
      "value" : [
        "../{{context.campaign_report_ref.link}}"
      ],
      "exposed" : false
    },
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "solicitud" : {
      "type" : "url",
      "value" : [
        "../{{context.solicitud_ref.link}}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.solicitud && $data.campaign_report ){",
        "\treturn {",
        "\t\t//map solicitud variable to expected task contract input",
        "\t\tsolicitudInput: {",
        "\t\t\tdistrito: $data.solicitud.distrito !== undefined ? $data.solicitud.distrito : null,",
        "\t\t\tfecha: $data.solicitud.fecha !== undefined ? $data.solicitud.fecha : null",
        "\t\t},",
        "\t\t//map campaign_report variable to expected task contract input",
        "\t\tcampaign_reportInput: {",
        "\t\t\tencargado: $data.campaign_report.encargado !== undefined ? $data.campaign_report.encargado : null,",
        "\t\t\thora_Inicio: $data.campaign_report.hora_Inicio !== undefined ? $data.campaign_report.hora_Inicio : null,",
        "\t\t\thora_Final: $data.campaign_report.hora_Final !== undefined ? $data.campaign_report.hora_Final : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    }
