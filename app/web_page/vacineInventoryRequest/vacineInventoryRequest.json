    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "solicitud" : {
      "type" : "url",
      "value" : [
        "../{{context.solicitud_ref.link}}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.solicitud ){",
        "\treturn {",
        "\t\t//map solicitud variable to expected task contract input",
        "\t\tsolicitudInput: {",
        "\t\t\tfecha: $data.solicitud.fecha !== undefined ? $data.solicitud.fecha : null,",
        "\t\t\tencargadoMaterial: $data.solicitud.encargadoMaterial !== undefined ? $data.solicitud.encargadoMaterial : null,",
        "\t\t\tqty: $data.solicitud.qty !== undefined ? $data.solicitud.qty : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
