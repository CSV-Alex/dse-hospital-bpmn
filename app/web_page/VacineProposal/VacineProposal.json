      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.solicitud ){",
        "\treturn {",
        "\t\t//map solicitud variable to expected task contract input",
        "\t\tsolicitudInput: {",
        "\t\t\tdistrito: $data.solicitud.distrito !== undefined ? $data.solicitud.distrito : null,",
        "\t\t\tfecha: $data.solicitud.fecha !== undefined ? $data.solicitud.fecha : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
