    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.ordenPago && $data.ordenPago_prueba ){",
        "\t//attach lazy references variables to parent variables",
        "\t$data.ordenPago.prueba = $data.ordenPago_prueba;",
        "\treturn {",
        "\t\t//map ordenPago variable to expected task contract input",
        "\t\tordenPagoInput: {",
        "\t\t\tcosto: $data.ordenPago.costo !== undefined ? $data.ordenPago.costo : null,",
        "\t\t\tprueba: $data.ordenPago.prueba ? {",
        "\t\t\t\tpersistenceId_string: $data.ordenPago.prueba.persistenceId_string !== undefined ? $data.ordenPago.prueba.persistenceId_string : null",
        "\t\t\t} : null",
        "\t\t}",
        "\t}",
        "}"
